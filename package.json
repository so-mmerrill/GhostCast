{
  "name": "ghostcast",
  "version": "0.1.0",
  "private": true,
  "description": "GhostCast - Modern scheduling application with plugin architecture",
  "author": "GhostCast Team",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.14.2",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules",
    "db:generate": "pnpm --filter @ghostcast/database generate",
    "db:migrate": "pnpm --filter @ghostcast/database migrate:dev",
    "db:push": "pnpm --filter @ghostcast/database push",
    "db:studio": "pnpm --filter @ghostcast/database studio",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  }
}
